<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Tourtoto 2026 - Admin login</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; background:#f5f4f0; color:#1c1c1c; display:flex; align-items:center; justify-content:center; min-height:100vh; margin:0; }
  .box { background:#fff; border:1px solid #ddd; border-radius:10px; padding:28px; width:320px; }
  h1 { font-size:1.15rem; margin:0 0 6px; }
  p.sub { color:#777; font-size:0.85rem; margin:0 0 18px; }
  label { display:block; font-size:0.85rem; color:#555; margin-bottom:4px; }
  input[type=password] { width:100%; padding:8px; border:1px solid #ccc; border-radius:6px; margin-bottom:12px; font-size:1rem; }
  button { width:100%; padding:9px; border-radius:6px; border:1px solid #999; background:#2e8b3d; color:#fff; font-size:0.95rem; cursor:pointer; }
  .error { background:#ffe9e9; border:1px solid #e4a; color:#a11; padding:8px 12px; border-radius:6px; font-size:0.85rem; margin-bottom:12px; }
</style>
</head>
<body>
  <div class="box">
    {% if mode == 'setup' %}
    <h1>Admin-wachtwoord instellen</h1>
    <p class="sub">Eerste keer hier - kies een wachtwoord voor de admin-pagina.</p>
    {% if error %}<div class="error">{{ error }}</div>{% endif %}
    <form method="post">
      <label>Wachtwoord</label>
      <input type="password" name="password" required autofocus>
      <label>Herhaal wachtwoord</label>
      <input type="password" name="password2" required>
      <button type="submit">Instellen &amp; inloggen</button>
    </form>
    {% else %}
    <h1>Admin login</h1>
    <p class="sub">Tourtoto 2026</p>
    {% if error %}<div class="error">{{ error }}</div>{% endif %}
    <form method="post">
      <label>Wachtwoord</label>
      <input type="password" name="password" required autofocus>
      <button type="submit">Inloggen</button>
    </form>
    {% endif %}
  </div>
</body>
</html>
