<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Tourtoto 2026</title>
<style>
  :root {
    --geel: #FFD700;
    --groen: #2E8B3D;
    --bol: #E4002B;
    --wit: #f5f5f5;
    --bg: #f7f7f5;
    --card: #ffffff;
    --ink: #1c1c1c;
    --muted: #6b6b6b;
    --border: #e4e2dc;
    --record: #8e44ad;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
    background: var(--bg);
    color: var(--ink);
  }
  header {
    background: linear-gradient(90deg, var(--geel), #fff3b0);
    padding: 28px 20px;
    border-bottom: 4px solid var(--ink);
  }
  header h1 { margin: 0; font-size: 1.9rem; }
  header p { margin: 6px 0 0; color: #333; font-size: 0.95rem; }
  main { max-width: 1100px; margin: 0 auto; padding: 24px 16px 60px; }
  section { margin-bottom: 40px; }
  h2 {
    font-size: 1.3rem;
    border-left: 6px solid var(--groen);
    padding-left: 10px;
    margin-bottom: 14px;
  }
  h2.pannen { border-left-color: var(--bol); }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    overflow-x: auto;
  }
  table { border-collapse: collapse; width: 100%; font-size: 0.92rem; }
  th, td { padding: 7px 10px; text-align: left; white-space: nowrap; }
  thead th { border-bottom: 2px solid var(--ink); font-weight: 600; }
  tbody tr:nth-child(odd) { background: #fafaf8; }
  tbody tr:hover { background: #fff6d8; }
  .total { font-weight: 700; }
  .pending {
    color: var(--muted);
    font-style: italic;
    padding: 20px;
    text-align: center;
  }
  .joker { background: var(--bol); color: white; border-radius: 4px; padding: 1px 6px; font-size: 0.78rem; }
  details {
    background: var(--card);
    border: 1px solid var(--border);
    border-left: 4px solid var(--groen);
    border-radius: 8px;
    margin-bottom: 8px;
    padding: 10px 14px;
    transition: background 0.15s ease;
  }
  details:hover { background: #f7fbf8; }
  details summary {
    cursor: pointer;
    font-weight: 600;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .chevron { display: inline-block; color: var(--groen); transition: transform 0.15s ease; margin-right: 8px; }
  details[open] .chevron { transform: rotate(90deg); }
  .stage-preview { font-weight: 400; font-size: 0.85rem; color: var(--muted); }
  .roster-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 12px; }
  @media (max-width: 700px) { .roster-grid { grid-template-columns: 1fr; } }
  .roster-grid ol { margin: 4px 0; padding-left: 22px; }
  .roster-grid h4 { margin: 0 0 4px; font-size: 0.95rem; color: var(--muted); }
  .bonus-answers { margin-top: 10px; font-size: 0.9rem; color: #444; }
  .bonus-answers div { margin-top: 3px; }
  .unresolved { color: var(--bol); text-decoration: underline dotted; cursor: help; }
  .stage-cell { width: 3em; text-align: center; }
  td.stage-cell { cursor: help; }
  .joker-cell { background: var(--geel); font-weight: 700; border-radius: 5px; }
  .breakdown-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 12px; }
  @media (max-width: 700px) { .breakdown-grid { grid-template-columns: 1fr; } }
  .breakdown-grid h4 { margin: 0 0 4px; font-size: 0.9rem; color: var(--muted); }
  .breakdown-grid table { font-size: 0.88rem; }
  .rank-num { color: var(--muted); width: 1.5em; }
  .muted-note { color: var(--muted); font-size: 0.85rem; font-style: italic; margin: 0; }
  .rider-name { cursor: help; border-bottom: 1px dotted var(--muted); }
  footer { text-align: center; color: var(--muted); font-size: 0.82rem; padding: 20px; }
  th.latest-stage { background: var(--groen); color: #fff; }
  td.latest-stage { background: #eaf5ec; }
  td.latest-stage.joker-cell { background: var(--geel); }
  td.record-cell { border: 2px solid var(--record); color: var(--record); font-weight: 700; }
  .rank-change { font-size: 0.78rem; font-weight: 700; margin-left: 6px; }
  .rank-up { color: var(--groen); }
  .rank-down { color: var(--bol); }
  .rank-same { color: var(--muted); }
  .tooltip-popup {
    display: none;
    position: fixed;
    z-index: 1000;
    max-width: 260px;
    background: #222;
    color: #fff;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 0.82rem;
    line-height: 1.4;
    white-space: pre-line;
    pointer-events: none;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
  }
</style>
</head>
<body>

<header>
  <h1>Tourtoto 2026</h1>
  <p>
    {{ stages_available|length }} van de {{ total_stages }} etappes verwerkt
    {% if final_available %}&middot; eindklassement bekend{% endif %}
    &middot; laatst bijgewerkt: {{ generated_at }}
  </p>
</header>

<main>

{% macro rider_attrs(name) -%}
{%- if name in rider_info -%}
{%- set info = rider_info[name] -%}
class="rider-name" data-tooltip="#{{ info.slot }} in {{ info.team }}
{{ info.n_owners }}/{{ info.n_participants }} keer gekozen
Uitgevallen: {{ 'Ja' if info.withdrawn else 'Nee' }}"
{%- endif -%}
{%- endmacro %}

{% macro rank_badge(name, changes) -%}
{%- if name in changes and changes[name] != 0 -%}
{%- set delta = changes[name] -%}
<span class="rank-change {{ 'rank-up' if delta > 0 else 'rank-down' }}">{% if delta > 0 %}&#9650;{% else %}&#9660;{% endif %}{{ delta|abs }}</span>
{%- endif -%}
{%- endmacro %}

  {% if not stages_available %}
  <section>
    <div class="card">
      <div class="pending">Nog geen etappe-uitslagen geladen. Het klassement verschijnt zodra de eerste etappe is verwerkt.</div>
    </div>
  </section>
  {% endif %}

  {% if stages_available %}
  <section>
    <h2>Hoofdpoule</h2>
    <div class="card">
      <table>
        <thead>
          <tr>
            <th>Naam</th>
            {% for s in stages_available %}<th class="stage-cell {{ 'latest-stage' if s == stages_available[-1] else '' }}">E{{ s }}</th>{% endfor %}
            <th>Totaal</th>
          </tr>
        </thead>
        <tbody>
          {% for p in hoofd_ranked %}
          <tr>
            <td>{{ p.name }}{{ rank_badge(p.name, hoofd_rank_changes) }}</td>
            {% for s in stages_available %}
            {% set st = p.hoofdploeg.by_stage[s|string] %}
            {% set is_record = (p.name, s) in dagscore_cells %}
            <td class="stage-cell {{ 'joker-cell' if st.joker else '' }} {{ 'latest-stage' if s == stages_available[-1] else '' }} {{ 'record-cell' if is_record else '' }}" data-tooltip="{{ st.tooltip }}{% if is_record %}

Hoogste dagscore! ({{ dagscore_record }} punten){% endif %}">{{ st.score }}</td>
            {% endfor %}
            <td class="total">{{ p.hoofdploeg.total }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Puntenverdeling per etappe</h2>
    {% for s in stages_available|reverse %}
    {% set b = stage_breakdowns[s|string] %}
    <details {% if loop.first %}open{% endif %}>
      <summary>
        <span><span class="chevron">&#9656;</span>Etappe {{ s }}</span>
        {% if b.components.stage_result %}
        <span class="stage-preview">Winnaar: {{ b.components.stage_result[0].rider }}</span>
        {% elif b.components.gc %}
        <span class="stage-preview">Geel: {{ b.components.gc[0].rider }}</span>
        {% endif %}
      </summary>
      <div class="breakdown-grid">
        {% for key, label in [('gc','Gele trui'), ('points','Groene trui'), ('mountains','Bergtrui (bolletjes)'), ('youth','Witte trui'), ('stage_result','Dag-uitslag (etappe)')] %}
        <div>
          <h4>{{ label }}</h4>
          {% if b.components[key] %}
          <table>
            <tbody>
              {% for row in b.components[key] %}
              <tr><td class="rank-num">{{ row.rank }}</td><td {{ rider_attrs(row.rider) }}>{{ row.rider }}</td><td class="total">{{ row.points }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
          {% else %}
          <p class="muted-note">Geen gegevens{% if key == 'stage_result' %} (ploegentijdrit: geen individuele dag-uitslag){% endif %}.</p>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      <h4 style="margin-top:16px;">Totaal per renner deze etappe</h4>
      <table>
        <thead><tr><th>Renner</th><th>Punten</th></tr></thead>
        <tbody>
          {% for row in b.totals %}
          <tr><td {{ rider_attrs(row.rider) }}>{{ row.rider }}</td><td class="total">{{ row.points }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </details>
    {% endfor %}
  </section>

  <section>
    <h2 class="pannen">Pannenkoekenpoule</h2>
    <div class="card">
      <table>
        <thead>
          <tr>
            <th>Naam</th>
            {% for s in stages_available %}<th class="stage-cell {{ 'latest-stage' if s == stages_available[-1] else '' }}">E{{ s }}</th>{% endfor %}
            <th>Totaal</th>
          </tr>
        </thead>
        <tbody>
          {% for p in pannen_ranked %}
          <tr>
            <td>{{ p.name }}{{ rank_badge(p.name, pannen_rank_changes) }}</td>
            {% for s in stages_available %}
            {% set st = p.pannenkoeken.by_stage[s|string] %}
            <td class="stage-cell {{ 'latest-stage' if s == stages_available[-1] else '' }}" data-tooltip="{{ st.tooltip }}">{{ st.score }}</td>
            {% endfor %}
            <td class="total">{{ p.pannenkoeken.total }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  <section>
    <h2>Teams &amp; koersvragen</h2>
    {% for name, roster in rosters.items() %}
    <details>
      <summary>
        <span><span class="chevron">&#9656;</span>{{ name }}</span>
        {% if roster.joker_stage %}<span class="joker">joker: etappe {{ roster.joker_stage }}</span>{% endif %}
      </summary>
      <div class="roster-grid">
        <div>
          <h4>Hoofdploeg</h4>
          <ol>
            {% for r in roster.hoofdploeg %}<li>{% if r.rider in unresolved_names %}<span class="unresolved" data-tooltip="Naam niet herkend op de merkploegen-lijst. Klopt de spelling?">{{ r.rider }}</span>{% else %}{{ r.rider }}{% endif %}{% if r.rider in rider_info %} <span style="color:var(--muted)">({{ rider_info[r.rider].team }})</span>{% endif %}</li>{% endfor %}
          </ol>
        </div>
        <div>
          <h4>Pannenkoekenploeg</h4>
          {% if roster.pannenkoeken %}
          <ol>
            {% for r in roster.pannenkoeken %}<li>{% if r.rider in unresolved_names %}<span class="unresolved" data-tooltip="Naam niet herkend op de merkploegen-lijst. Klopt de spelling?">{{ r.rider }}</span>{% else %}{{ r.rider }}{% endif %}</li>{% endfor %}
          </ol>
          {% else %}
          <p style="color:var(--muted); font-style:italic;">Nog niet ingeleverd</p>
          {% endif %}
        </div>
      </div>
      <div class="bonus-answers">
        <strong>Bonusvragen:</strong>
        <div>podium: {{ roster.bonus_answers.podium|join(', ') if roster.bonus_answers.podium else '?' }}</div>
        <div>tijdsverschil: {{ roster.bonus_answers.gap_seconds if roster.bonus_answers.gap_seconds is not none else '?' }}s</div>
        <div>uitvallers: {{ roster.bonus_answers.dnf_count if roster.bonus_answers.dnf_count is not none else '?' }}</div>
      </div>
    </details>
    {% endfor %}
  </section>

</main>

<footer>Tourtoto 2026 &middot; Mitchel Castelyns</footer>

<div id="tooltip-popup" class="tooltip-popup"></div>
<script>
(function () {
  var popup = document.getElementById('tooltip-popup');
  var active = null;

  function show(el) {
    popup.textContent = el.dataset.tooltip;
    popup.style.display = 'block';
    var rect = el.getBoundingClientRect();
    var popupRect = popup.getBoundingClientRect();
    var left = rect.left + rect.width / 2 - popupRect.width / 2;
    left = Math.max(8, Math.min(left, window.innerWidth - popupRect.width - 8));
    var top = rect.top - popupRect.height - 8;
    if (top < 8) top = rect.bottom + 8;
    popup.style.left = left + 'px';
    popup.style.top = top + 'px';
    active = el;
  }

  function hide() {
    popup.style.display = 'none';
    active = null;
  }

  // desktop hover
  document.addEventListener('mouseover', function (e) {
    var el = e.target.closest && e.target.closest('[data-tooltip]');
    if (el) show(el);
  });
  document.addEventListener('mouseout', function (e) {
    var el = e.target.closest && e.target.closest('[data-tooltip]');
    if (el && !el.contains(e.relatedTarget)) hide();
  });

  // mobile tap (and desktop click) - tap the same one again, or elsewhere, to close
  document.addEventListener('click', function (e) {
    var el = e.target.closest && e.target.closest('[data-tooltip]');
    if (el) {
      e.preventDefault();
      if (active === el) hide();
      else show(el);
    } else {
      hide();
    }
  });
})();
</script>

</body>
</html>
