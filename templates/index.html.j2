<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Tourtoto 2026</title>
<link rel="manifest" href="manifest.json">
<link rel="icon" href="favicon.ico">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<meta name="theme-color" content="#FFD700">
<script data-goatcounter="https://mcastelyns.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
<style>
  :root {
    --geel: #FFD700;
    --groen: #2E8B3D;
    --bol: #E4002B;
    --wit: #f5f5f5;
    --bg: #f7f7f5;
    --card: #ffffff;
    --ink: #1c1c1c;
    --muted: #6b6b6b;
    --border: #e4e2dc;
    --record: #8e44ad;
    --optimal: #b8860b;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
    background: var(--bg);
    color: var(--ink);
  }
  header {
    background: linear-gradient(90deg, var(--geel), #fff3b0);
    padding: 28px 20px;
    border-bottom: 4px solid var(--ink);
  }
  header h1 { margin: 0; font-size: 1.9rem; }
  header p { margin: 6px 0 0; color: #333; font-size: 0.95rem; }
  main { max-width: 1100px; margin: 0 auto; padding: 24px 16px 60px; }
  section { margin-bottom: 40px; }
  h2 {
    font-size: 1.3rem;
    border-left: 6px solid var(--groen);
    padding-left: 10px;
    margin-bottom: 14px;
  }
  h2.pannen { border-left-color: var(--bol); }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    overflow-x: auto;
  }
  table { border-collapse: collapse; width: 100%; font-size: 0.92rem; }
  th, td { padding: 7px 10px; text-align: left; white-space: nowrap; }
  thead th { border-bottom: 2px solid var(--ink); font-weight: 600; }
  tbody tr:nth-child(odd) { background: #fafaf8; }
  tbody tr:hover { background: #fff6d8; }
  .total { font-weight: 700; }
  .pending {
    color: var(--muted);
    font-style: italic;
    padding: 20px;
    text-align: center;
  }
  .joker { background: var(--bol); color: white; border-radius: 4px; padding: 1px 6px; font-size: 0.78rem; }
  details {
    background: var(--card);
    border: 1px solid var(--border);
    border-left: 4px solid var(--groen);
    border-radius: 8px;
    margin-bottom: 8px;
    padding: 10px 14px;
    transition: background 0.15s ease;
  }
  details:hover { background: #f7fbf8; }
  details summary {
    cursor: pointer;
    font-weight: 600;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .chevron { display: inline-block; color: var(--groen); transition: transform 0.15s ease; margin-right: 8px; }
  details[open] .chevron { transform: rotate(90deg); }
  .stage-preview { font-weight: 400; font-size: 0.85rem; color: var(--muted); }
  .roster-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 12px; }
  @media (max-width: 700px) { .roster-grid { grid-template-columns: 1fr; } }
  .roster-grid ol { margin: 4px 0; padding-left: 22px; }
  .roster-grid h4 { margin: 0 0 4px; font-size: 0.95rem; color: var(--muted); }
  .bonus-answers { margin-top: 10px; font-size: 0.9rem; color: #444; }
  .bonus-answers div { margin-top: 3px; }
  .unresolved { color: var(--bol); text-decoration: underline dotted; cursor: help; }
  .stage-cell { width: 3em; text-align: center; }
  td.stage-cell { cursor: help; }
  .joker-cell { background: var(--geel); font-weight: 700; border-radius: 5px; }
  .breakdown-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 12px; }
  @media (max-width: 700px) { .breakdown-grid { grid-template-columns: 1fr; } }
  .breakdown-grid h4 { margin: 0 0 4px; font-size: 0.9rem; color: var(--muted); }
  .breakdown-grid table { font-size: 0.88rem; }
  .rank-num { color: var(--muted); width: 1.5em; }
  .muted-note { color: var(--muted); font-size: 0.85rem; font-style: italic; margin: 0; }
  .rider-name { cursor: help; border-bottom: 1px dotted var(--muted); }
  footer { text-align: center; color: var(--muted); font-size: 0.82rem; padding: 20px; }
  th.total-sep, td.total-sep { border-left: 2px solid var(--ink); }
  td.record-cell { border: 2px solid var(--record); color: var(--record); font-weight: 700; }
  td.optimal-cell { border: 2px solid var(--optimal); color: var(--optimal); font-weight: 700; }
  td.record-cell.optimal-cell { border-style: double; border-width: 4px; }
  .optimal-team-line { font-weight: 400; font-size: 0.85rem; color: var(--optimal); }
  .rank-change { font-size: 0.78rem; font-weight: 700; margin-left: 6px; }
  .rank-up { color: var(--groen); }
  .rank-down { color: var(--bol); }
  .rank-same { color: var(--muted); }
  .day-toggle { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin-bottom: 10px; }
  .day-toggle-label { color: var(--muted); font-size: 0.85rem; margin-right: 4px; }
  .day-toggle button {
    border: 1px solid var(--border);
    background: #fff;
    border-radius: 999px;
    padding: 4px 12px;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--ink);
  }
  .day-toggle button:hover { background: #f0f0ee; }
  .day-toggle button.active { background: var(--groen); color: #fff; border-color: var(--groen); }
  .main-tabs {
    display: flex;
    gap: 4px;
    padding: 0 16px;
    background: var(--card);
    border-bottom: 3px solid var(--border);
  }
  .main-tabs button {
    border: none;
    background: transparent;
    color: var(--muted);
    padding: 14px 22px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    border-bottom: 4px solid transparent;
    margin-bottom: -3px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .main-tabs button.active { color: var(--groen); border-bottom-color: var(--groen); }
  .main-tabs button:hover:not(.active) { color: var(--ink); }
  .rider-points-card { max-height: 640px; overflow-y: auto; }
  .rider-points-card table thead th { position: sticky; top: 0; background: var(--card); }
  .withdrawn-tag { color: var(--bol); font-size: 0.78rem; font-style: italic; margin-left: 6px; }
  .rider-search { margin-bottom: 10px; }
  .rider-search input {
    width: 100%;
    max-width: 320px;
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.92rem;
    font-family: inherit;
  }
  .rider-search input:focus { outline: 2px solid var(--groen); }
  .gekozen-cell { cursor: help; }
  .chart-trigger {
    display: inline-block;
    border: 1px solid var(--border);
    background: #fff;
    border-radius: 8px;
    padding: 6px 14px;
    font-size: 0.85rem;
    cursor: pointer;
    margin-bottom: 10px;
  }
  .chart-trigger:hover { background: #f0f0ee; }
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: var(--card);
    border-radius: 12px;
    padding: 22px;
    max-width: 880px;
    width: 100%;
    max-height: 88vh;
    overflow-y: auto;
    position: relative;
  }
  .modal-box h3 { margin: 0 0 12px; padding-right: 24px; }
  .modal-close {
    position: absolute;
    top: 10px;
    right: 14px;
    border: none;
    background: none;
    font-size: 1.7rem;
    line-height: 1;
    cursor: pointer;
    color: var(--muted);
  }
  .modal-close:hover { color: var(--ink); }
  .chart-legend { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
  .chart-legend-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.8rem;
    cursor: pointer;
    padding: 3px 9px;
    border-radius: 6px;
    border: 1px solid var(--border);
    user-select: none;
  }
  .chart-legend-item.dimmed { opacity: 0.35; }
  .chart-legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
  .tooltip-popup {
    display: none;
    position: fixed;
    z-index: 1000;
    max-width: 260px;
    background: #222;
    color: #fff;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 0.82rem;
    line-height: 1.4;
    white-space: pre-line;
    pointer-events: none;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
  }
</style>
</head>
<body>

<header>
  <h1>Tourtoto 2026</h1>
  <p>
    {{ stages_available|length }} van de {{ total_stages }} etappes verwerkt
    {% if final_available %}&middot; eindklassement bekend{% endif %}
    &middot; laatst bijgewerkt: {{ generated_at }}
  </p>
</header>

<div class="main-tabs">
  <button type="button" data-tab="klassement" class="active">Klassement</button>
  <button type="button" data-tab="renners">Punten per renner</button>
</div>

<main>

{% macro rider_attrs(name) -%}
{%- if name in rider_info -%}
{%- set info = rider_info[name] -%}
class="rider-name" data-tooltip="#{{ info.slot }} in {{ info.team }}
{{ info.n_owners }}/{{ info.n_participants }} keer gekozen
Uitgevallen: {{ 'Ja' if info.withdrawn else 'Nee' }}"
{%- endif -%}
{%- endmacro %}

{% macro rank_badge(name, changes) -%}
{%- set delta = changes.get(name, 0) -%}
<span class="rank-change {{ 'rank-up' if delta > 0 else ('rank-down' if delta < 0 else '') }}" {% if delta == 0 %}style="display:none"{% endif %}>{% if delta > 0 %}&#9650;{% elif delta < 0 %}&#9660;{% endif %}{{ delta|abs if delta != 0 else '' }}</span>
{%- endmacro %}

<div id="tab-klassement" class="tab-panel">

  {% if not stages_available %}
  <section>
    <div class="card">
      <div class="pending">Nog geen etappe-uitslagen geladen. Het klassement verschijnt zodra de eerste etappe is verwerkt.</div>
    </div>
  </section>
  {% endif %}

  {% if stages_available %}
  <section>
    <h2>Hoofdpoule</h2>
    {% if stages_available|length > 1 %}
    <button type="button" class="chart-trigger" data-chart="hoofd">Puntenverloop</button>
    <div class="day-toggle">
      <span class="day-toggle-label">Stand na:</span>
      {% for s in stages_available %}<button type="button" data-day="{{ s }}">Dag {{ s }}</button>{% endfor %}
      <button type="button" data-day="latest" class="active">Actueel</button>
    </div>
    {% endif %}
    <div class="card">
      <table id="hoofd-table" data-latest-stage="{{ stages_available[-1] }}">
        <thead>
          <tr>
            <th>Naam</th>
            {% for s in stages_available %}<th class="stage-cell" data-stage="{{ s }}">E{{ s }}</th>{% endfor %}
            <th class="total-sep">Totaal</th>
          </tr>
        </thead>
        <tbody>
          {% for p in hoofd_ranked %}
          <tr data-name="{{ p.name }}" data-total="{{ p.hoofdploeg.total }}" data-joker-stage="{{ p.joker_stage or '' }}"{% for s in stages_available %} data-cum{{ s }}="{{ p.hoofdploeg.by_stage[s|string].cumulative }}"{% if s in hoofd_rank_changes_by_stage %} data-delta{{ s }}="{{ hoofd_rank_changes_by_stage[s].get(p.name, 0) }}"{% endif %}{% endfor %}>
            <td>{{ p.name }}{{ rank_badge(p.name, hoofd_rank_changes) }}</td>
            {% for s in stages_available %}
            {% set st = p.hoofdploeg.by_stage[s|string] %}
            {% set is_record = (p.name, s) in dagscore_cells %}
            {% set is_optimal = (p.name, s) in optimal_cells %}
            <td class="stage-cell {{ 'joker-cell' if st.joker else '' }} {{ 'record-cell' if is_record else '' }} {{ 'optimal-cell' if is_optimal else '' }}" data-stage="{{ s }}" data-tooltip="{{ st.tooltip }}{% if is_record %}

Hoogste dagscore! ({{ dagscore_record }} punten){% endif %}{% if is_optimal %}

Optimale hoofdploeg dit etappe! (perfecte score volgens de regels){% endif %}">{{ st.score }}</td>
            {% endfor %}
            <td class="total total-cell total-sep">{{ p.hoofdploeg.total }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Puntenverdeling per etappe</h2>
    {% for s in stages_available|reverse %}
    {% set b = stage_breakdowns[s|string] %}
    <details {% if loop.first %}open{% endif %}>
      <summary>
        <span><span class="chevron">&#9656;</span>Etappe {{ s }}</span>
        {% if b.components.stage_result %}
        <span class="stage-preview">Winnaar: {{ b.components.stage_result[0].rider }}</span>
        {% elif b.components.gc %}
        <span class="stage-preview">Geel: {{ b.components.gc[0].rider }}</span>
        {% endif %}
        {% if b.optimal_hoofdploeg %}
        <span class="optimal-team-line">Optimale hoofdploeg: {{ b.optimal_hoofdploeg.score }} punten</span>
        {% endif %}
      </summary>
      <div class="breakdown-grid">
        {% for key, label in [('gc','Gele trui'), ('points','Groene trui'), ('mountains','Bergtrui (bolletjes)'), ('youth','Witte trui'), ('stage_result','Dag-uitslag (etappe)'), ('optimal_hoofdploeg','Optimale hoofdploeg')] %}
        {% set rows = b.optimal_hoofdploeg.slots if (key == 'optimal_hoofdploeg' and b.optimal_hoofdploeg) else b.components[key] %}
        <div>
          <h4>{{ label }}{% if key == 'optimal_hoofdploeg' and b.optimal_hoofdploeg %} ({{ b.optimal_hoofdploeg.score }} punten){% endif %}</h4>
          {% if rows %}
          <table>
            <tbody>
              {% for row in rows %}
              <tr><td class="rank-num">{{ row.rank }}</td>{% if key == 'optimal_hoofdploeg' and row.points == 0 %}<td>-</td>{% else %}<td {{ rider_attrs(row.rider) }}>{{ row.rider }}</td>{% endif %}<td class="total">{{ row.points }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
          {% else %}
          <p class="muted-note">Geen gegevens{% if key == 'stage_result' %} (ploegentijdrit: geen individuele dag-uitslag){% endif %}.</p>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      <h4 style="margin-top:16px;">Totaal per renner deze etappe</h4>
      <table>
        <thead><tr><th>Renner</th><th>Punten</th></tr></thead>
        <tbody>
          {% for row in b.totals %}
          <tr><td {{ rider_attrs(row.rider) }}>{{ row.rider }}</td><td class="total">{{ row.points }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </details>
    {% endfor %}
  </section>

  <section>
    <h2 class="pannen">Pannenkoekenpoule</h2>
    {% if stages_available|length > 1 %}
    <button type="button" class="chart-trigger" data-chart="pannen">Puntenverloop</button>
    {% endif %}
    <div class="card">
      <table id="pannen-table" data-latest-stage="{{ stages_available[-1] }}">
        <thead>
          <tr>
            <th>Naam</th>
            {% for s in stages_available %}<th class="stage-cell" data-stage="{{ s }}">E{{ s }}</th>{% endfor %}
            <th class="total-sep">Totaal</th>
          </tr>
        </thead>
        <tbody>
          {% for p in pannen_ranked %}
          <tr data-name="{{ p.name }}" data-total="{{ p.pannenkoeken.total }}"{% for s in stages_available %} data-cum{{ s }}="{{ p.pannenkoeken.by_stage[s|string].cumulative }}"{% if s in pannen_rank_changes_by_stage %} data-delta{{ s }}="{{ pannen_rank_changes_by_stage[s].get(p.name, 0) }}"{% endif %}{% endfor %}>
            <td>{{ p.name }}{{ rank_badge(p.name, pannen_rank_changes) }}</td>
            {% for s in stages_available %}
            {% set st = p.pannenkoeken.by_stage[s|string] %}
            <td class="stage-cell" data-stage="{{ s }}" data-tooltip="{{ st.tooltip }}">{{ st.score }}</td>
            {% endfor %}
            <td class="total total-cell total-sep">{{ p.pannenkoeken.total }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  <section>
    <h2>Teams &amp; koersvragen</h2>
    {% for name, roster in rosters.items() %}
    <details>
      <summary>
        <span><span class="chevron">&#9656;</span>{{ name }}</span>
        {% if roster.joker_stage %}<span class="joker">joker: etappe {{ roster.joker_stage }}</span>{% endif %}
      </summary>
      <div class="roster-grid">
        <div>
          <h4>Hoofdploeg</h4>
          <ol>
            {% for r in roster.hoofdploeg %}<li>{% if r.rider in unresolved_names %}<span class="unresolved" data-tooltip="Naam niet herkend op de merkploegen-lijst. Klopt de spelling?">{{ r.rider }}</span>{% else %}{{ r.rider }}{% endif %}{% if r.rider in rider_info %} <span style="color:var(--muted)">({{ rider_info[r.rider].team }})</span>{% endif %}</li>{% endfor %}
          </ol>
        </div>
        <div>
          <h4>Pannenkoekenploeg</h4>
          {% if roster.pannenkoeken %}
          <ol>
            {% for r in roster.pannenkoeken %}<li>{% if r.rider in unresolved_names %}<span class="unresolved" data-tooltip="Naam niet herkend op de merkploegen-lijst. Klopt de spelling?">{{ r.rider }}</span>{% else %}{{ r.rider }}{% endif %}</li>{% endfor %}
          </ol>
          {% else %}
          <p style="color:var(--muted); font-style:italic;">Nog niet ingeleverd</p>
          {% endif %}
        </div>
      </div>
      <div class="bonus-answers">
        <strong>Bonusvragen:</strong>
        <div>podium: {{ roster.bonus_answers.podium|join(', ') if roster.bonus_answers.podium else '?' }}</div>
        <div>tijdsverschil: {{ roster.bonus_answers.gap_seconds if roster.bonus_answers.gap_seconds is not none else '?' }}s</div>
        <div>uitvallers: {{ roster.bonus_answers.dnf_count if roster.bonus_answers.dnf_count is not none else '?' }}</div>
      </div>
    </details>
    {% endfor %}
  </section>

</div>

<div id="tab-renners" class="tab-panel" style="display:none">
  <section>
    <h2>Punten per renner</h2>
    <div class="rider-search">
      <input type="text" id="rider-search-input" placeholder="Zoek op naam of team...">
    </div>
    <div class="card rider-points-card">
      <table id="rider-points-table">
        <thead>
          <tr><th>Renner</th><th>Team</th><th>Punten</th><th>Gekozen</th></tr>
        </thead>
        <tbody>
          {% for r in rider_leaderboard %}
          <tr data-search="{{ (r.rider ~ ' ' ~ r.team)|lower }}">
            <td>{{ r.rider }}{% if r.withdrawn %}<span class="withdrawn-tag">uitgevallen</span>{% endif %}</td>
            <td style="color:var(--muted)">{{ r.team }}</td>
            <td class="total">{{ r.points }}</td>
            <td class="gekozen-cell" data-tooltip="{{ r.owners|join('\n') if r.owners else 'Door niemand gekozen' }}">{{ r.owners|length }}/{{ r.n_participants }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
</div>

</main>

<footer>Tourtoto 2026 &middot; Mitchel Castelyns</footer>

<div id="tooltip-popup" class="tooltip-popup"></div>

<div id="chart-modal" class="modal-overlay">
  <div class="modal-box">
    <button type="button" class="modal-close" aria-label="Sluiten">&times;</button>
    <h3 id="chart-title"></h3>
    <p id="chart-caption" class="muted-note" style="margin-bottom:10px;"></p>
    <div id="chart-container"></div>
    <div id="chart-legend" class="chart-legend"></div>
  </div>
</div>

<script>
(function () {
  var popup = document.getElementById('tooltip-popup');
  var active = null;

  function show(el) {
    popup.textContent = el.dataset.tooltip;
    popup.style.display = 'block';
    var rect = el.getBoundingClientRect();
    var popupRect = popup.getBoundingClientRect();
    var left = rect.left + rect.width / 2 - popupRect.width / 2;
    left = Math.max(8, Math.min(left, window.innerWidth - popupRect.width - 8));
    var top = rect.top - popupRect.height - 8;
    if (top < 8) top = rect.bottom + 8;
    popup.style.left = left + 'px';
    popup.style.top = top + 'px';
    active = el;
  }

  function hide() {
    popup.style.display = 'none';
    active = null;
  }

  // desktop hover
  document.addEventListener('mouseover', function (e) {
    var el = e.target.closest && e.target.closest('[data-tooltip]');
    if (el) show(el);
  });
  document.addEventListener('mouseout', function (e) {
    var el = e.target.closest && e.target.closest('[data-tooltip]');
    if (el && !el.contains(e.relatedTarget)) hide();
  });

  // mobile tap (and desktop click) - tap the same one again, or elsewhere, to close
  document.addEventListener('click', function (e) {
    var el = e.target.closest && e.target.closest('[data-tooltip]');
    if (el) {
      e.preventDefault();
      if (active === el) hide();
      else show(el);
    } else {
      hide();
    }
  });
})();

(function () {
  var toggle = document.querySelector('.day-toggle');
  if (!toggle) return;
  var buttons = toggle.querySelectorAll('button');

  function applyDay(tableId, day, ascending) {
    var table = document.getElementById(tableId);
    if (!table) return;

    table.querySelectorAll('[data-stage]').forEach(function (el) {
      var visible = day === 'latest' || parseInt(el.dataset.stage, 10) <= day;
      el.style.display = visible ? '' : 'none';
    });

    var tbody = table.querySelector('tbody');
    var rows = Array.from(tbody.querySelectorAll('tr'));

    function valueFor(tr) {
      var raw = day === 'latest' ? tr.dataset.total : tr.dataset['cum' + day];
      return raw !== undefined ? parseFloat(raw) : 0;
    }

    var deltaStage = day === 'latest' ? table.dataset.latestStage : String(day);
    rows.forEach(function (tr) {
      var totalCell = tr.querySelector('.total-cell');
      if (totalCell) totalCell.textContent = valueFor(tr);
      var badge = tr.querySelector('.rank-change');
      if (!badge) return;
      var raw = tr.dataset['delta' + deltaStage];
      var delta = raw !== undefined ? parseInt(raw, 10) : 0;
      if (delta === 0) {
        badge.style.display = 'none';
        badge.textContent = '';
        badge.classList.remove('rank-up', 'rank-down');
      } else {
        badge.style.display = '';
        badge.classList.toggle('rank-up', delta > 0);
        badge.classList.toggle('rank-down', delta < 0);
        badge.textContent = (delta > 0 ? '▲' : '▼') + Math.abs(delta);
      }
    });

    rows.sort(function (a, b) {
      return ascending ? valueFor(a) - valueFor(b) : valueFor(b) - valueFor(a);
    });
    rows.forEach(function (tr) { tbody.appendChild(tr); });
  }

  buttons.forEach(function (btn) {
    btn.addEventListener('click', function () {
      buttons.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var day = btn.dataset.day === 'latest' ? 'latest' : parseInt(btn.dataset.day, 10);
      applyDay('hoofd-table', day, false);
      applyDay('pannen-table', day, true);
    });
  });
})();

(function () {
  var tabButtons = document.querySelectorAll('.main-tabs button');
  tabButtons.forEach(function (btn) {
    btn.addEventListener('click', function () {
      tabButtons.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      document.querySelectorAll('.tab-panel').forEach(function (panel) {
        panel.style.display = panel.id === 'tab-' + btn.dataset.tab ? '' : 'none';
      });
    });
  });
})();

(function () {
  var input = document.getElementById('rider-search-input');
  if (!input) return;
  var rows = Array.from(document.querySelectorAll('#rider-points-table tbody tr'));
  input.addEventListener('input', function () {
    var q = input.value.trim().toLowerCase();
    rows.forEach(function (tr) {
      tr.style.display = tr.dataset.search.indexOf(q) === -1 ? 'none' : '';
    });
  });
})();

(function () {
  var overlay = document.getElementById('chart-modal');
  var triggers = document.querySelectorAll('.chart-trigger');
  if (!overlay || !triggers.length) return;
  var titleEl = document.getElementById('chart-title');
  var captionEl = document.getElementById('chart-caption');
  var container = document.getElementById('chart-container');
  var legend = document.getElementById('chart-legend');

  function color(i, n) {
    return 'hsl(' + Math.round((360 * i) / n) + ', 65%, 45%)';
  }

  function collectSeries(tableId) {
    var table = document.getElementById(tableId);
    var stages = Array.from(table.querySelectorAll('thead th[data-stage]')).map(function (th) {
      return parseInt(th.dataset.stage, 10);
    });
    var series = Array.from(table.querySelectorAll('tbody tr')).map(function (tr) {
      return {
        name: tr.dataset.name,
        jokerStage: tr.dataset.jokerStage ? parseInt(tr.dataset.jokerStage, 10) : null,
        values: stages.map(function (s) {
          var raw = tr.dataset['cum' + s];
          return raw !== undefined ? parseFloat(raw) : 0;
        }),
      };
    });
    return { stages: stages, series: series };
  }

  function buildSvg(data) {
    var width = 780, height = 420;
    var pad = { top: 16, right: 16, bottom: 30, left: 42 };
    var innerW = width - pad.left - pad.right;
    var innerH = height - pad.top - pad.bottom;
    var n = data.stages.length;
    var maxVal = Math.max.apply(null, [0].concat(data.series.reduce(function (acc, s) { return acc.concat(s.values); }, [])));

    function x(i) { return pad.left + (n <= 1 ? innerW / 2 : (innerW * i) / (n - 1)); }
    function y(v) { return pad.top + innerH - (maxVal === 0 ? 0 : (innerH * v) / maxVal); }

    var parts = ['<svg viewBox="0 0 ' + width + ' ' + height + '" width="100%" style="max-width:100%;height:auto;">'];

    var ticks = 5;
    for (var t = 0; t <= ticks; t++) {
      var val = Math.round((maxVal * t) / ticks);
      var yy = y(val);
      parts.push('<line x1="' + pad.left + '" y1="' + yy + '" x2="' + (width - pad.right) + '" y2="' + yy + '" stroke="#e4e2dc" stroke-width="1"/>');
      parts.push('<text x="' + (pad.left - 8) + '" y="' + (yy + 4) + '" font-size="11" fill="#6b6b6b" text-anchor="end">' + val + '</text>');
    }
    data.stages.forEach(function (s, i) {
      parts.push('<text x="' + x(i) + '" y="' + (height - pad.bottom + 18) + '" font-size="11" fill="#6b6b6b" text-anchor="middle">E' + s + '</text>');
    });

    data.series.forEach(function (s, idx) {
      var c = color(idx, data.series.length);
      var points = s.values.map(function (v, i) { return x(i) + ',' + y(v); }).join(' ');
      parts.push('<polyline data-series="' + idx + '" points="' + points + '" fill="none" stroke="' + c + '" stroke-width="2" opacity="0.85"/>');
      s.values.forEach(function (v, i) {
        if (s.jokerStage === data.stages[i]) {
          parts.push('<circle data-series="' + idx + '" cx="' + x(i) + '" cy="' + y(v) + '" r="6" fill="none" stroke="' + c + '" stroke-width="2"/>');
        }
        parts.push('<circle data-series="' + idx + '" cx="' + x(i) + '" cy="' + y(v) + '" r="2.5" fill="' + c + '"/>');
      });
    });

    parts.push('</svg>');
    return parts.join('');
  }

  function buildLegend(data) {
    legend.innerHTML = '';
    data.series.forEach(function (s, idx) {
      var c = color(idx, data.series.length);
      var item = document.createElement('span');
      item.className = 'chart-legend-item';
      item.innerHTML = '<span class="chart-legend-dot" style="background:' + c + '"></span>' + s.name;
      item.addEventListener('click', function () {
        var hidden = item.classList.toggle('dimmed');
        container.querySelectorAll('[data-series="' + idx + '"]').forEach(function (el) {
          el.style.display = hidden ? 'none' : '';
        });
      });
      legend.appendChild(item);
    });
  }

  function openChart(kind) {
    var tableId = kind === 'hoofd' ? 'hoofd-table' : 'pannen-table';
    titleEl.textContent = kind === 'hoofd'
      ? 'Puntenverloop - Hoofdpoule'
      : 'Puntenverloop - Pannenkoekenpoule (laagste wint)';
    captionEl.textContent = kind === 'hoofd' ? 'Open stip = jokeretappe' : '';
    var data = collectSeries(tableId);
    container.innerHTML = buildSvg(data);
    buildLegend(data);
    overlay.classList.add('open');
  }

  triggers.forEach(function (btn) {
    btn.addEventListener('click', function () { openChart(btn.dataset.chart); });
  });
  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) overlay.classList.remove('open');
  });
  overlay.querySelector('.modal-close').addEventListener('click', function () {
    overlay.classList.remove('open');
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') overlay.classList.remove('open');
  });
})();
</script>

</body>
</html>
